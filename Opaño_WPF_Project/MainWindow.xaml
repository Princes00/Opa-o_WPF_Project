<Window x:Class="Opaño_WPF_Project.MainWindow"
      
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contact Manager" Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0" CornerRadius="10" Padding="10"
                Background="#2D2D30" Margin="5"
                BorderBrush="#3E3E42" BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Contact List"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="5"
                           Foreground="White"/>

                <DataGrid x:Name="dataGrid"
                          AutoGenerateColumns="False"
                          Height="320"
                          Margin="5"
                          RowHeight="30"
                          FontSize="13"
                          Background="#2D2D30"
                          Foreground="White"
                          RowBackground="#2D2D30"
                          AlternatingRowBackground="#252526"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          SelectionChanged="dataGrid_SelectionChanged">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#3E3E42"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*" />
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <Button x:Name="btnDeleteData"
                        Content="DELETE"
                        Height="45"
                        Margin="5"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#D9534F"
                        Foreground="White"
                        BorderThickness="0"
                        IsEnabled="False"
                        Click="btnDeleteData_Click"/>
            </StackPanel>
        </Border>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="1" CornerRadius="10" Padding="15"
                Background="#2D2D30" Margin="5"
                BorderBrush="#3E3E42" BorderThickness="1">

            <StackPanel>

                <TextBlock Text="Contact Details"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="White"/>

                <!-- Name -->
                <TextBlock Text="Name" Foreground="#CCCCCC"/>
                <TextBox x:Name="txtName"
                         Height="30"
                         Margin="0,5,0,10"
                         Padding="5"
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderBrush="#555"/>

                <!-- Phone -->
                <TextBlock Text="Phone" Foreground="#CCCCCC"/>
                <TextBox x:Name="txtPhone"
                         Height="30"
                         Margin="0,5,0,10"
                         Padding="5"
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderBrush="#555"/>

                <!-- Email -->
                <TextBlock Text="Email" Foreground="#CCCCCC"/>
                <TextBox x:Name="txtEmail"
                         Height="30"
                         Margin="0,5,0,15"
                         Padding="5"
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderBrush="#555"/>

                <!-- Save -->
                <Button x:Name="btnSave"
                        Content="SAVE"
                        Height="45"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#28A745"
                        Foreground="White"
                        BorderThickness="0"
                        Click="btnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
